{
  "version": 2,
  "builds": [
    {
      "src": "api/*.ts",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "destination": "/api/health.ts"
    },
    {
      "source": "/mcp",
      "destination": "/api/mcp.ts"
    },
    {
      "source": "/api/health",
      "destination": "/api/health.ts"
    },
    {
      "source": "/api/mcp",
      "destination": "/api/mcp.ts"
    }
  ]
}
